# Example environment variables — DO NOT commit real secrets.
# Copy this file to `.env` and fill in your real values.

# Formsubmit or other form endpoint (if using direct provider)
FORMSUBMIT_EMAIL=your-email@example.com

# Example API keys (third-party services)
THIRD_PARTY_API_KEY=replace_with_api_key

# Database connection (use a managed DB and keep credentials secret)
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=replace_with_db_password
